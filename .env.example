# LLM Provider: claude | openai | ollama | mock
LLM_PROVIDER=mock

# Anthropic (Claude)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# OpenAI
OPENAI_API_KEY=your-openai-api-key-here

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# App Settings
OUTPUT_DIR=output
DATA_DIR=data
