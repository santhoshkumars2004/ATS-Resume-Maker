# LLM Provider: codex | copilot | llama
LLM_PROVIDER=codex

# Codex CLI
CODEX_MODEL=gpt-5.4

# GitHub Copilot CLI
COPILOT_MODEL=gpt-4.1

# Llama via Ollama or a remote Ollama-compatible endpoint
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# App Settings
OUTPUT_DIR=output
DATA_DIR=data
